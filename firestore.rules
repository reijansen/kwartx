rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authUid() {
      return request.auth.uid;
    }

    function hasAuthEmail() {
      return request.auth.token.email != null &&
        request.auth.token.email is string &&
        request.auth.token.email != '';
    }

    function authEmailNormalized() {
      return request.auth.token.email.lower();
    }

    function isInviteSender(data) {
      return data.senderUid == authUid();
    }

    function isInviteRecipient(data) {
      return hasAuthEmail() &&
        data.recipientEmailNormalized is string &&
        data.recipientEmailNormalized == authEmailNormalized();
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && userId == authUid();

      match /expenses/{expenseId} {
        allow read, write: if isSignedIn() && userId == authUid();
      }

      match /roommates/{roommateId} {
        allow read, write: if isSignedIn() && userId == authUid();
      }
    }

    match /invites/{inviteId} {
      allow read: if isSignedIn() &&
        (isInviteSender(resource.data) || isInviteRecipient(resource.data));

      allow create: if isSignedIn() &&
        request.resource.data.senderUid == authUid() &&
        request.resource.data.senderEmail is string &&
        request.resource.data.recipientEmail is string &&
        request.resource.data.recipientEmailNormalized is string &&
        request.resource.data.status == 'pending';

      allow update: if isSignedIn() &&
        (isInviteSender(resource.data) || isInviteRecipient(resource.data));

      allow delete: if isSignedIn() && isInviteSender(resource.data);
    }

    // Mail queue should not be readable from clients.
    match /mail/{docId} {
      allow read: if false;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
